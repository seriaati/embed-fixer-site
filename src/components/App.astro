---
import Layout from "../layouts/Layout.astro";
import { DEFAULT_LOCALE, getDictionary, localeOptions } from "../i18n";

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = getDictionary(lang);

const brandName = "Embed Fixer";
const logoPath = "/logo.png";
const platformIconMonochrome = "DCEBFF";
const githubIconMonochrome = "DCEBFF";
const platforms = [
    { name: "Twitter/X", slug: "x" },
    { name: "Pixiv", slug: "pixiv" },
    { name: "TikTok", slug: "tiktok" },
    { name: "Reddit", slug: "reddit" },
    { name: "Instagram", slug: "instagram" },
    { name: "FurAffinity", slug: "furaffinity" },
    { name: "Twitch Clips", slug: "twitch" },
    { name: "Iwara", slug: null },
    { name: "Bluesky", slug: "bluesky" },
    { name: "Kemono", slug: null },
    { name: "Facebook", slug: "facebook" },
    { name: "Bilibili", slug: "bilibili" },
    { name: "Tumblr", slug: "tumblr" },
    { name: "Threads", slug: "threads" },
    { name: "PTT", slug: null },
    { name: "DeviantArt", slug: "deviantart" },
];
const statValues = ["1200+", "150+"];
---

<Layout
    lang={lang}
    title={t.meta.title}
    description={t.meta.description}
    ogImage="/og-image.png"
>
    <main class="shell">
        <section class="section hero reveal">
            <div class="hero-copy">
                <div class="brand-row">
                    <div
                        class="logo-slot logo-slot--circle logo-slot--filled"
                        aria-label="Embed Fixer logo"
                    >
                        <img
                            src={logoPath}
                            alt="Embed Fixer logo"
                            class="logo-image"
                            loading="lazy"
                        />
                    </div>
                </div>
                <p class="eyebrow" id="brand-name">{brandName}</p>
                <h1 id="hero-heading">{t.hero.heading}</h1>
                <p class="hero-tagline" id="hero-tagline">
                    {t.hero.tagline}
                </p>
                <div class="cta-row">
                    <a
                        href="https://discord.com/oauth2/authorize?client_id=770144963735453696"
                        target="_blank"
                        rel="noreferrer"
                        class="cta cta--primary"
                    >
                        <span id="cta-add-top">{t.hero.ctaAdd}</span>
                    </a>
                    <a
                        href="https://github.com/seriaati/embed-fixer"
                        target="_blank"
                        rel="noreferrer"
                        class="cta cta--secondary"
                    >
                        <img
                            src={`https://cdn.simpleicons.org/github/${githubIconMonochrome}?viewbox=auto`}
                            alt=""
                            aria-hidden="true"
                            class="cta-icon"
                            loading="lazy"
                            decoding="async"
                        />
                        <span id="cta-github-top">{t.hero.ctaGithub}</span>
                    </a>
                </div>
            </div>

            <aside class="relay" id="relay" aria-label={t.hero.relay.ariaLabel}>
                <div class="relay-row">
                    <span class="relay-label" id="relay-incoming-label"
                        >{t.hero.relay.incomingLabel}</span
                    >
                    <span id="relay-incoming-value"
                        >{t.hero.relay.incomingValue}</span
                    >
                </div>
                <div class="relay-row">
                    <span class="relay-label" id="relay-action-label"
                        >{t.hero.relay.actionLabel}</span
                    >
                    <span id="relay-action-value"
                        >{t.hero.relay.actionValue}</span
                    >
                </div>
                <div class="relay-row">
                    <span class="relay-label" id="relay-result-label"
                        >{t.hero.relay.resultLabel}</span
                    >
                    <span id="relay-result-value"
                        >{t.hero.relay.resultValue}</span
                    >
                </div>
            </aside>
        </section>

        <section class="section problem reveal delay-1">
            <div>
                <p class="eyebrow" id="problem-eyebrow">{t.problem.eyebrow}</p>
                <h2 id="problem-heading">{t.problem.heading}</h2>
            </div>
            <ul class="problem-list" id="problem-list">
                {t.problem.items.map((item) => <li>{item}</li>)}
            </ul>
        </section>

        <section class="section reveal delay-1">
            <p class="eyebrow" id="features-eyebrow">{t.features.eyebrow}</p>
            <h2 id="features-heading" style="margin-top: 0.35rem;">
                {t.features.heading}
            </h2>
            <div
                class="feature-rail"
                id="feature-rail"
                style="margin-top: 1.1rem;"
            >
                {
                    t.features.items.map((feature, index) => (
                        <article class="feature">
                            <div class="feature-index">
                                {String(index + 1).padStart(2, "0")}
                            </div>
                            <p>{feature}</p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="section customization reveal delay-1">
            <p class="eyebrow" id="customization-eyebrow">
                {t.customization.eyebrow}
            </p>
            <h2 id="customization-heading" style="margin-top: 0.35rem;">
                {t.customization.heading}
            </h2>
            <p class="customization-intro" id="customization-body">
                {t.customization.body}
            </p>
            <p class="customization-note" id="customization-reset-note">
                {t.customization.resetNote}
            </p>
            <ul
                class="customization-grid"
                id="customization-grid"
                aria-label={t.customization.ariaLabel}
            >
                {
                    t.customization.settings.map((setting) => (
                        <li class="customization-item">
                            <h3>{setting.label}</h3>
                            <p>{setting.description}</p>
                        </li>
                    ))
                }
            </ul>
        </section>

        <section class="section reveal delay-2">
            <p class="eyebrow" id="platforms-eyebrow">{t.platforms.eyebrow}</p>
            <h2 id="platforms-heading" style="margin-top: 0.35rem;">
                {t.platforms.heading}
            </h2>
            <div
                class="platform-grid"
                id="platform-grid"
                role="list"
                aria-label={t.platforms.ariaLabel}
            >
                {
                    platforms.map((platform) => (
                        <div class="platform" role="listitem">
                            {platform.slug ? (
                                <img
                                    class="platform-icon"
                                    src={`https://cdn.simpleicons.org/${platform.slug}/${platformIconMonochrome}?viewbox=auto`}
                                    alt=""
                                    loading="lazy"
                                    decoding="async"
                                    aria-hidden="true"
                                />
                            ) : (
                                <span
                                    class="platform-icon platform-icon--fallback"
                                    aria-hidden="true"
                                >
                                    {platform.name.charAt(0).toUpperCase()}
                                </span>
                            )}
                            <span>{platform.name}</span>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="section proof reveal delay-2">
            <p class="eyebrow" id="proof-eyebrow">{t.proof.eyebrow}</p>
            <h2 id="proof-heading" style="margin-top: 0.35rem;">
                {t.proof.heading}
            </h2>
            <div
                class="proof-grid"
                id="proof-grid"
                role="list"
                aria-label={t.proof.ariaLabel}
            >
                {
                    statValues.map((value, index) => (
                        <article class="proof-card" role="listitem">
                            <p class="proof-value">{value}</p>
                            <p class="proof-label">
                                {t.proof.statLabels[index]}
                            </p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="section hosting reveal delay-2">
            <div>
                <p class="eyebrow" id="hosting-eyebrow">{t.hosting.eyebrow}</p>
                <h2 id="hosting-heading" style="margin-top: 0.35rem;">
                    {t.hosting.heading}
                </h2>
                <p
                    id="hosting-body"
                    style="margin-top: 0.7rem; max-width: 60ch;"
                >
                    {t.hosting.body}
                </p>
                <div class="cta-row" style="margin-top: 1rem;">
                    <a
                        href="https://github.com/seriaati/embed-fixer#self-hosting"
                        target="_blank"
                        rel="noreferrer"
                        class="cta cta--secondary"
                    >
                        <img
                            src={`https://cdn.simpleicons.org/github/${githubIconMonochrome}?viewbox=auto`}
                            alt=""
                            aria-hidden="true"
                            class="cta-icon"
                            loading="lazy"
                            decoding="async"
                        />
                        <span id="hosting-cta">{t.hosting.cta}</span>
                    </a>
                </div>
            </div>
            <div
                class="hosting-tags"
                id="hosting-tags"
                aria-label="Deployment options"
            >
                {t.hosting.tags.map((tag) => <span>{tag}</span>)}
            </div>
        </section>

        <section class="closing reveal delay-2">
            <p class="eyebrow" id="closing-eyebrow">{t.closing.eyebrow}</p>
            <h2 id="closing-heading">{t.closing.heading}</h2>
            <p id="closing-body">{t.closing.body}</p>
            <div class="cta-row">
                <a
                    href="https://discord.com/oauth2/authorize?client_id=770144963735453696"
                    target="_blank"
                    rel="noreferrer"
                    class="cta cta--primary"
                >
                    <span id="cta-add-bottom">{t.hero.ctaAdd}</span>
                </a>
                <a
                    href="https://github.com/seriaati/embed-fixer"
                    target="_blank"
                    rel="noreferrer"
                    class="cta cta--secondary"
                >
                    <img
                        src={`https://cdn.simpleicons.org/github/${githubIconMonochrome}?viewbox=auto`}
                        alt=""
                        aria-hidden="true"
                        class="cta-icon"
                        loading="lazy"
                        decoding="async"
                    />
                    <span id="cta-github-bottom">{t.hero.ctaGithub}</span>
                </a>
            </div>
        </section>

        <footer class="site-footer" aria-label="Site footer">
            <div class="site-footer-row">
                <p id="footer-copyright">{t.footer.copyright}</p>
                <div
                    class="language-selector"
                    role="group"
                    aria-labelledby="language-label"
                >
                    <label
                        class="language-label"
                        id="language-label"
                        for="language-select-trigger"
                    >
                        {t.languageSelector.label}
                    </label>
                    <button
                        id="language-select-trigger"
                        class="language-select-trigger"
                        type="button"
                        aria-label={t.languageSelector.ariaLabel}
                        aria-haspopup="listbox"
                        aria-expanded="false"
                        aria-controls="language-options"
                    >
                        <span id="language-current-label">
                            {
                                localeOptions.find(
                                    (locale: { code: string; label: string }) =>
                                        locale.code === lang,
                                )?.label
                            }
                        </span>
                        <span class="language-select-caret" aria-hidden="true">
                            <svg
                                viewBox="0 0 16 16"
                                fill="none"
                                aria-hidden="true"
                            >
                                <path
                                    d="M3.5 6.5L8 11L12.5 6.5"
                                    stroke="currentColor"
                                    stroke-width="1.6"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </span>
                    </button>
                    <ul
                        id="language-options"
                        class="language-select-menu"
                        role="listbox"
                        tabindex="-1"
                        hidden
                    >
                        {
                            localeOptions.map(
                                (locale: { code: string; label: string }) => (
                                    <li role="presentation">
                                        <button
                                            type="button"
                                            class="language-option"
                                            role="option"
                                            data-locale={locale.code}
                                            aria-selected={
                                                locale.code === lang
                                                    ? "true"
                                                    : "false"
                                            }
                                        >
                                            {locale.label}
                                        </button>
                                    </li>
                                ),
                            )
                        }
                    </ul>
                </div>
            </div>
        </footer>
    </main>
</Layout>

<script
    is:inline
    define:vars={{
        localeOptions,
        defaultLocale: DEFAULT_LOCALE,
    }}
>
    // --- Locale helpers ---

    const normalizeLocale = (inputLocale) => {
        if (!inputLocale) return defaultLocale;

        const lowered = String(inputLocale).toLowerCase();
        const exact = localeOptions.find(
            (option) => option.code.toLowerCase() === lowered,
        );
        if (exact) return exact.code;

        const base = lowered.split("-")[0];
        const partial = localeOptions.find(
            (option) =>
                option.code.toLowerCase() === base ||
                option.code.toLowerCase().startsWith(`${base}-`),
        );
        return partial?.code ?? defaultLocale;
    };

    const getLocaleHref = (localeCode) => `/${localeCode}/`;

    // --- Dropdown helpers ---

    const byId = (id) => document.getElementById(id);

    const getLanguageElements = () => {
        const trigger = byId("language-select-trigger");
        const menu = byId("language-options");
        const options = Array.from(
            document.querySelectorAll(".language-option"),
        );
        return { trigger, menu, options };
    };

    const closeLanguageMenu = () => {
        const { trigger, menu } = getLanguageElements();
        if (!trigger || !menu) return;
        trigger.setAttribute("aria-expanded", "false");
        menu.hidden = true;
    };

    const openLanguageMenu = () => {
        const { trigger, menu } = getLanguageElements();
        if (!trigger || !menu) return;
        trigger.setAttribute("aria-expanded", "true");
        menu.hidden = false;
    };

    const focusOption = (option) => {
        if (option) option.focus();
    };

    const getSelectedOption = () => {
        const { options } = getLanguageElements();
        return options.find(
            (option) => option.getAttribute("aria-selected") === "true",
        );
    };

    const moveFocus = (direction) => {
        const { options } = getLanguageElements();
        const activeIndex = options.findIndex(
            (option) => option === document.activeElement,
        );
        const selectedIndex = options.indexOf(
            getSelectedOption() ?? options[0],
        );
        const current = activeIndex >= 0 ? activeIndex : selectedIndex;
        focusOption(
            options[(current + direction + options.length) % options.length],
        );
    };

    // --- Navigate on locale choose ---

    const chooseLocale = (localeCode) => {
        window.location.href = getLocaleHref(normalizeLocale(localeCode));
    };

    // --- Wire up events ---

    const initLanguageSelector = () => {
        const { trigger, menu, options } = getLanguageElements();
        if (!trigger || !menu || options.length === 0) return;

        trigger.addEventListener("click", () => {
            const isExpanded = trigger.getAttribute("aria-expanded") === "true";
            if (isExpanded) {
                closeLanguageMenu();
            } else {
                openLanguageMenu();
                focusOption(getSelectedOption() ?? options[0]);
            }
        });

        trigger.addEventListener("keydown", (e) => {
            if (e.key === "ArrowDown" || e.key === "ArrowUp") {
                e.preventDefault();
                openLanguageMenu();
                focusOption(
                    e.key === "ArrowDown"
                        ? (getSelectedOption() ?? options[0])
                        : options[options.length - 1],
                );
            }
        });

        options.forEach((option) => {
            option.addEventListener("click", () =>
                chooseLocale(option.dataset.locale),
            );
        });

        menu.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                e.preventDefault();
                closeLanguageMenu();
                trigger.focus();
                return;
            }
            if (e.key === "ArrowDown") {
                e.preventDefault();
                moveFocus(1);
                return;
            }
            if (e.key === "ArrowUp") {
                e.preventDefault();
                moveFocus(-1);
                return;
            }
            if (e.key === "Home") {
                e.preventDefault();
                focusOption(options[0]);
                return;
            }
            if (e.key === "End") {
                e.preventDefault();
                focusOption(options[options.length - 1]);
                return;
            }
            if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                const active = document.activeElement;
                if (active?.classList?.contains("language-option")) {
                    chooseLocale(active.dataset.locale);
                }
            }
        });

        document.addEventListener("click", (e) => {
            if (!(e.target instanceof Node)) return;
            if (!menu.contains(e.target) && !trigger.contains(e.target)) {
                closeLanguageMenu();
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closeLanguageMenu();
        });
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLanguageSelector, {
            once: true,
        });
    } else {
        initLanguageSelector();
    }
</script>
