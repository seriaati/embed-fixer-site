---
import "../styles/global.css";
import { localeOptions, DEFAULT_LOCALE } from "../i18n";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	lang?: string;
}

const {
	title = "Embed Fixer",
	description = "Feature-rich Discord bot for fixing social media embeds.",
	ogImage = "/logo.png",
	lang = "en",
} = Astro.props;

const baseUrl = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const ogImageUrl = new URL(ogImage, baseUrl).toString();

const getLocaleUrl = (code: string) => {
	const isDefault = code === DEFAULT_LOCALE;
	return new URL(isDefault ? "/" : `/${code}/`, baseUrl).toString();
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin="anonymous"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600&family=Schibsted+Grotesk:wght@500;600&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		{
			localeOptions.map((option) => (
				<link
					rel="alternate"
					hreflang={option.code}
					href={getLocaleUrl(option.code)}
				/>
			))
		}
		<link
			rel="alternate"
			hreflang="x-default"
			href={getLocaleUrl(DEFAULT_LOCALE)}
		/>

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={`${title} preview image`} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
