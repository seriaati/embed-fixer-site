---
import App from "../components/App.astro";
import { DEFAULT_LOCALE, getLocaleFromHeaders } from "../i18n";

const preferredLocale = getLocaleFromHeaders(
    Astro.request.headers.get("accept-language"),
);

if (preferredLocale !== DEFAULT_LOCALE) {
    return Astro.redirect(`/${preferredLocale}/`, 302);
}
---

<App lang={DEFAULT_LOCALE} />
